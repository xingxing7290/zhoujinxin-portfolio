{
  admin off
  default_sni 113.44.50.108
}

https://113.44.50.108 {
  tls /etc/letsencrypt/live/113.44.50.108/fullchain.pem /etc/letsencrypt/live/113.44.50.108/privkey.pem
  encode zstd gzip
  reverse_proxy app:8080 {
    health_uri /api/health
    health_interval 30s
    health_timeout 3s
  }
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    -Server
  }
  log {
    output stdout
    format json
  }
}

http://113.44.50.108 {
  redir https://113.44.50.108{uri} permanent
}

http://113-44-50-108.sslip.io {
  redir https://113.44.50.108{uri} permanent
}
